# Prefer the SharePoint connector path in Power Apps runtime.
# Set to false only when you want to force Power Automate HTTP/local defaults.
VITE_REFERENCE_PREFER_SHAREPOINT_CONNECTOR=true

# SharePoint site + folder path for reference files.
VITE_REFERENCE_SHAREPOINT_SITE_URL=https://microsoft.sharepoint.com/teams/APACGSC
VITE_REFERENCE_SHAREPOINT_FOLDER_PATH=/App Reference/PowerApps/ParticipantTemplateGenerator/Reference

# Optional Power Automate HTTP trigger fallback (used when connector load fails or connector is disabled).
VITE_REFERENCE_FLOW_URL=
VITE_REFERENCE_FLOW_KEY=

# Set to false if you want the app to fail fast when remote load fails.
VITE_REFERENCE_ALLOW_LOCAL_FALLBACK=true
